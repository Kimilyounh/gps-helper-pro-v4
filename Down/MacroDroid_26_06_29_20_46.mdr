,"moveOption":0,"option":1,"padding":8,"preventRemoveByDrag":false,"shadowColor":-16777216,"showOverStatusBar":false,"singleLineScrollingEnabled":false,"textColor":-1,"textSize":14,"textToDisplay":"","updateLocation":false,"updateVariableOnMove":false,"variableWidth":true,"vibrateOnClick":false,"widthPercentage":90,"xPosition":0.5,"yPosition":0.5,"disableLogging":false,"m_SIGUID":-5708166473261244140,"m_classType":"FloatingTextAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_delayInMilliSeconds":200,"m_delayInSeconds":0,"m_useAlarm":false,"unitForVariables":0,"disableLogging":false,"m_SIGUID":-8610797419671265785,"m_classType":"PauseAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"emailSubject":"스크린샷","m_mechanismOption":0,"m_option":0,"saveToJpeg":false,"screenshotFormat":0,"uiOption":0,"useSmtpEmail":false,"disableLogging":false,"m_SIGUID":-9172866474903157419,"m_classType":"TakeScreenshotAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"m_delayInMilliSeconds":600,"m_delayInSeconds":0,"m_useAlarm":false,"unitForVariables":0,"disableLogging":false,"m_SIGUID":-8743275405320660269,"m_classType":"PauseAction","m_comment":"스크린샷 디스크 저장 대기","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"blockNextAction":true,"m_nonRoot":true,"m_script":"# \u003d\u003d\u003d 포커OCR 셸 (v10: 동시 실행 락 추가) \u003d\u003d\u003d\nLOCK\u003d/sdcard/poker_run.lock\n# in-flight 중 재탭이면 무시 (락이 30초 이상 묵었으면 강제 해제)\nif [ -f \"$LOCK\" ]; then\n  AGE\u003d$(( $(date +%s) - $(stat -c %Y \"$LOCK\" 2\u003e/dev/null || echo 0) ))\n  [ \"$AGE\" -lt 30 ] \u0026\u0026 { printf \u0027BUSY\u0027; exit 0; }\nfi\necho $$ \u003e \"$LOCK\"\ntrap \u0027rm -f \"$LOCK\"\u0027 EXIT\n\nSS1\u003d/storage/emulated/0/DCIM/Screenshots\nSS2\u003d/storage/emulated/0/Pictures/Screenshots\nTMP\u003d/sdcard/poker_shot.bin\nPREV_FILE\u003d/sdcard/poker_prev_board.txt\nTMP_BODY\u003d/sdcard/poker_body.txt\nTMP_HDR\u003d/sdcard/poker_hdr.txt\n\nnewest() { ls -t \"$SS1\"/*.jpg \"$SS1\"/*.png \"$SS2\"/*.jpg \"$SS2\"/*.png 2\u003e/dev/null | head -n 1; }\n\n# 1) 안정·완전한 스샷을 임시본으로 확보 (최대 6회)\nOK\u003d0\ni\u003d0\nwhile [ \"$i\" -lt 6 ]; do\n  i\u003d$((i+1))\n  L\u003d$(newest)\n  [ -z \"$L\" ] \u0026\u0026 { sleep 0.4; continue; }\n  cp \"$L\" \"$TMP\" 2\u003e/dev/null\n  S1\u003d$(wc -c \u003c \"$TMP\" 2\u003e/dev/null)\n  [ -z \"$S1\" ] \u0026\u0026 S1\u003d0\n  if [ \"$S1\" -ge 50000 ]; then\n    sleep 0.3\n    cp \"$L\" \"$TMP\" 2\u003e/dev/null\n    S2\u003d$(wc -c \u003c \"$TMP\" 2\u003e/dev/null)\n    [ -z \"$S2\" ] \u0026\u0026 S2\u003d0\n    if [ \"$S1\" \u003d \"$S2\" ]; then OK\u003d1; break; fi\n  fi\n  sleep 0.4\ndone\nif [ \"$OK\" !\u003d 1 ]; then echo \"ERR: screenshot not ready (size\u003d$S1)\"; exit 0; fi\n\n# 2) 직전 보드(메모리용)\nPREV\u003d\"\"\n[ -f \"$PREV_FILE\" ] \u0026\u0026 PREV\u003d$(cat \"$PREV_FILE\" 2\u003e/dev/null | tr -d \u0027\\r\\n\u0027 | tr \u0027 \u0027 \u0027,\u0027)\n\n# 3) URL  (hv\u003d0: 분석/보드 캡처 — 가려진 홀은 옛것으로 상속 안 함, 저장된 홀만 재사용. prev 실제 부착.)\nBASE\u003d\"https://poker256ai-1.topjoa.workers.dev/?lang\u003dko\u0026format\u003dline\u0026sharpen\u003d1\u0026w\u003d1600\u0026token\u003dILOVEYOUKSTA\u0026hxf\u003d0.231\u0026hyf\u003d0.722\u0026hwf\u003d0.125\u0026hhf\u003d0.160\u0026hcw\u003d832\u0026bxf\u003d0.401\u0026byf\u003d0.672\u0026bwf\u003d0.189\u0026bhf\u003d0.154\u0026bcw\u003d832\u0026hv\u003d0\"\nURL\u003d\"$BASE\"\n[ -n \"$PREV\" ] \u0026\u0026 URL\u003d\"$BASE\u0026prev\u003d$PREV\"\n\n# 4) 전송 (임시본 전송, 4회 백오프 2/3/5초)\nA\u003d0; CODE\u003d\"\"; SUC\u003d0\nwhile [ \"$A\" -lt 4 ]; do\n  A\u003d$((A+1))\n  : \u003e \"$TMP_HDR\"; : \u003e \"$TMP_BODY\"\n  curl -s -X POST \"$URL\" -H \"Content-Type: image/jpeg\" -H \"Expect:\" \\\n       --data-binary @\"$TMP\" --connect-timeout 10 --max-time 60 \\\n       -D \"$TMP_HDR\" -o \"$TMP_BODY\"\n  CODE\u003d$(grep -i \"^HTTP/\" \"$TMP_HDR\" 2\u003e/dev/null | tail -1 | awk \u0027{print $2}\u0027)\n  if [ \"$CODE\" \u003d \"200\" ] \u0026\u0026 [ -s \"$TMP_BODY\" ]; then SUC\u003d1; break; fi\n  [ \"$A\" -lt 4 ] \u0026\u0026 { case \"$A\" in 1) sleep 2;; 2) sleep 3;; *) sleep 5;; esac; }\ndone\n\n# 5) 결과\nif [ \"$SUC\" !\u003d 1 ]; then\n  echo \"ERR: http\u003d$CODE $(head -c 120 \"$TMP_BODY\" 2\u003e/dev/null)\"\n  exit 0\nfi\ncat \"$TMP_BODY\"","m_variableToSaveResponse":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"result","m_stringValue":"","m_type":2,"supportsInput":false,"supportsOutput":true},"timeoutSeconds":600,"useHelper":false,"useShizuku":false,"disableLogging":false,"m_SIGUID":-6909579239462018868,"m_classType":"ShellScriptAction","m_comment":"","m_constraintList":[],"m_isDisabled":false,"m_isOrCondition":false},{"childrenCollapsed":false,"dontLogIfConditionIsFalse":false,"disableLogging":false,"m_SIGUID":-8348032968855361846,"m_classType":"IfConditionAction","m_comment":"","m_constraintList":[{"checkCase":false,"dictionaryKeys":{"keys":[]},"dictionaryType":2,"enableRegex":false,"m_booleanValue":false,"m_doubleValue":0.0,"m_intCompareVariable":false,"m_intGreaterThan":false,"m_intLessThan":false,"m_intNotEqual":false,"m_intValue":0,"m_otherValueToCompare":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_name":"board","m_stringValue":"","m_type":1,"supportsInput":true,"supportsOutput":true},"m_stringComparisonType":0,"m_stringEqual":true,"m_stringValue":"BUSY","m_variable":{"dictionary":{"entries":[],"isArray":false,"variableType":4,"type":"Dictionary"},"isActionBlockWorkingVar":false,"isLocalVar":true,"isSecure":false,"m_booleanValue":false,"m_decimalValue":0.0,"m_intValue":0,"m_nam